# MongoDB — connection string and database name
# For local dev: mongodb://localhost:27017
# For production: mongodb://USER:PASS@HOST:PORT/?authSource=admin
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=your-database-name

# Rustfs / S3-compatible object storage endpoint
# For local dev: http://localhost:10000
# For production: https://rustfs-api.your-domain.com
RUSTFS_ENDPOINT=http://localhost:10000

# Rustfs access credentials (from Rustfs admin panel or config)
RUSTFS_ACCESS_KEY=your-access-key
RUSTFS_SECRET_KEY=your-secret-key

# Rustfs bucket name — created automatically if it does not exist
RUSTFS_BUCKET=your-bucket-name
